@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="@MyTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

```
<MudAppBar Elevation="1">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" Edge="Edge.Start" Color="Color.Inherit" />
