@using MudBlazor
@using SampleClassification.ConsoleApp

@page "/"
@rendermode InteractiveServer

<MudSlider T="double" @bind-Value="Pregnancies" Min="1" Max="20" Step="1" Color="Color.Info" />

<p>Pregnancy: @Pregnancies</p>

<MudSlider T="double" @bind-Value="Glucose" Min="1" Max="200" Step="1" Color="Color.Error" />

<p>Glucose: @Glucose</p>

<MudSlider T="double" @bind-Value="BloodPressure" Min="0" Max="120" Step="1" Color="Color.Secondary" />

<p>Blood Pressure: @BloodPressure</p>

<MudSlider T="double" @bind-Value="SkinThickness" Min="0" Max="50" Step="1" Color="Color.Tertiary" />

<p>Skin Thickness: @SkinThickness</p>

<MudSlider T="double" @bind-Value="Insulin" Min="0" Max="1000" Step="1" Color="Color.Info" />

<p>Insulin: @Insulin</p>

<MudSlider T="double" @bind-Value="BMI" Min="1" Max="50" Step="0.1" Color="Color.Error" />

<p>BMI: @BMI</p>

<MudSlider T="double" @bind-Value="DiabetesPedigreeFunction" Min="0" Max="1" Step="0.01" Color="Color.Secondary" />

<p>Diabetes Pedigree: @DiabetesPedigreeFunction</p>

<MudSlider T="double" @bind-Value="Age" Min="20" Max="70" Step="1" Color="Color.Tertiary" />

<p>Age: @Age</p>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DoCalculations">
    Predict
</MudButton>

<MudAlert Severity="Severity.Success">@result</MudAlert>

@code {


public double Pregnancies { get; set; } = 5;
public double Glucose { get; set; } = 100;
public double BloodPressure { get; set; } = 80;
public double SkinThickness { get; set; } = 20;
public double Insulin { get; set; } = 80;
public double BMI { get; set; } = 25;
public double DiabetesPedigreeFunction { get; set; } = 0.5;
public double Age { get; set; } = 30;

public string result = "";

public void DoCalculations()
{
    try
    {
        var sampleData = new SampleClassification.ModelInput()
        {
            Pregnancies = (float)Pregnancies,
            Glucose = (float)Glucose,
            BloodPressure = (float)BloodPressure,
            SkinThickness = (float)SkinThickness,
            Insulin = (float)Insulin,
            BMI = (float)BMI,
            DiabetesPedigreeFunction = (float)DiabetesPedigreeFunction,
            Age = (float)Age
        };

        var predictions = SampleClassification.PredictAllLabels(sampleData);

        if (predictions != null && predictions.Any())
        {
            var top = predictions.First();
            result = $"Predicted: {top.Key} ({(top.Value * 100):0.00}%)";
        }
        else
        {
            result = "No prediction returned.";
        }
    }
    catch (Exception ex)
    {
        result = $"Error: {ex.Message}";
    }
}


}
